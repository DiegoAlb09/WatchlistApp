@page "/login"
@layout AuthLayout
@inject AuthService Auth
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<div class="auth-page">
  <div class="auth-card">
    <h1>
      <Icon Name="film" /> Mi Watchlist
    </h1>
    <p class="auth-subtitle">Inicia sesión para ver tu watchlist</p>

    <EditForm Model="modelo" OnValidSubmit="Enviar" class="form-agregar">
      <label>Correo</label>
      <input type="email" @bind="modelo.Email" placeholder="tu@correo.com" />

      <label>Contraseña</label>
      <input type="password" @bind="modelo.Password" placeholder="••••••••" />

      @if (!string.IsNullOrWhiteSpace(error))
      {
        <p class="rango-error">@error</p>
      }

      <div class="form-buttons">
        <button type="submit" class="btn-add" disabled="@cargando">
          @(cargando ? "Entrando..." : "Iniciar sesión")
        </button>
      </div>
    </EditForm>

    <p class="auth-footer">¿No tienes cuenta? <a href="/registro">Regístrate</a></p>
  </div>
</div>

@code {
  private class Modelo
  {
    public string Email { get; set; } = "";
    public string Password { get; set; } = "";
  }

  private Modelo modelo = new();
  private string? error;
  private bool cargando;

  protected override async Task OnInitializedAsync()
  {
    // Si ya hay sesion iniciada, no tiene sentido mostrar el login.
    var estado = await AuthProvider.GetAuthenticationStateAsync();
    if (estado.User.Identity?.IsAuthenticated == true)
      Nav.NavigateTo("/");
  }

  private async Task Enviar()
  {
    error = null;
    cargando = true;

    var resultado = await Auth.IniciarSesionAsync(modelo.Email, modelo.Password);
    cargando = false;

    if (!resultado.Exitoso)
    {
      error = resultado.Error;
      return;
    }

    Nav.NavigateTo("/", forceLoad: true);
  }
}
